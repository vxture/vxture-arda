PROJECT_NAME=arda
NODE_NAME=ARDA_DEPLOY_HOST

ROOT_DIR=/srv/md0/arda
REPO_DIR=/srv/md0/arda/deploy
RUNTIME_DIR=/srv/md0/arda/runtime
DATA_DIR=/srv/md0/arda/data
BACKUP_DIR=/srv/md0/arda/backup

APEX_DOMAIN=arda.vxture.com
APP_PUBLISH_PORT=3230

OIDC_ISSUER=https://accounts.vxture.com
OIDC_CLIENT_ID=arda
OIDC_CLIENT_SECRET=ChangeME
OIDC_REDIRECT_URI=https://arda.vxture.com/auth/callback
OIDC_SCOPES="openid profile email phone"
OIDC_POST_LOGOUT_REDIRECT_URI=https://arda.vxture.com/

REDIS_URL=redis://arda-redis:6379
RP_SESSION_TTL=2592000

POSTGRES_USER=arda
POSTGRES_PASSWORD=ChangeME
POSTGRES_DB=arda
DATABASE_URL=postgresql://arda:ChangeME@arda-db:5432/arda?schema=public
RP_SESSION_COOKIE_NAME=vx_rp_session
RP_SESSION_COOKIE_DOMAIN=arda.vxture.com

DEFAULT_LANDING=/dashboard
MOCK_TIER=pro

IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=vxture
IMAGE_TAG=latest
FALLBACK_IMAGE_REGISTRY=crpi-l3l7g186zpo2if7p.cn-hangzhou.personal.cr.aliyuncs.com
FALLBACK_IMAGE_NAMESPACE=agentos
VXTURE_NPM_REGISTRY=https://npm.pkg.github.com
NODE_AUTH_TOKEN=ChangeME
