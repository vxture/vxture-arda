# Deploy package runtime overrides.
# Optional deploy-host env overlay.
# The operator .env at $ROOT_DIR/etc/.env remains required for full runtime
# configuration. Copy this file to deploy/.env only when this deployment
# package needs deploy-host-specific overrides (it is sourced after etc/.env).

IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=vxture
IMAGE_TAG=latest

# Aliyun ACR fallback. If a GHCR pull fails, 23-start-docker-services.sh retries
# the whole image set against this registry/namespace.
# FALLBACK_IMAGE_REGISTRY=registry.cn-hangzhou.aliyuncs.com
# FALLBACK_IMAGE_NAMESPACE=vxture

# Optional registry login values for manual runs.
# CI/CD injects registry credentials through GitHub Actions secrets.
# REGISTRY_USERNAME=
# REGISTRY_PASSWORD=
