# Arda runtime configuration template.
#
# On the server the real config lives at $ROOT_DIR/etc/.env (etc/ is the
# persistent operator-config home). deploy/ is disposable (CI rsyncs the subset
# there, no git clone); runtime/ is regenerated; data/ is the only backed-up
# state tree. REPO_DIR points at deploy/ (scripts reference it).
#
# The SAME scripts deploy prod or beta. Which stack runs is decided entirely by
# this file and the root it lives under:
#   prod : /srv/md0/arda/etc/.env       (values below as-is)
#   beta : /srv/md1/arda-beta/etc/.env  (apply the "BETA OVERRIDES" at the bottom)

# -- Node / Project Identity ---------------------------------------------------
# PROJECT_NAME drives the compose project name AND the container_name prefix, so
# prod (arda-*) and beta (arda-beta-*) never collide on the same host.
PROJECT_NAME=arda
NODE_NAME=ARDA_DEPLOY_HOST

# -- Server Paths --------------------------------------------------------------
# the deploy host has two RAID-1 arrays: md0 (1.8T, prod data) and md1 (916G, beta
# data). Deploy scripts and configs live under ROOT_DIR on the root filesystem;
# persistent state (redis AOF) lives under DATA_DIR on the RAID array so it
# survives root-disk failure. REPO_DIR = ROOT_DIR/deploy (CI rsync target).
ROOT_DIR=/srv/md0/arda
REPO_DIR=/srv/md0/arda/deploy
RUNTIME_DIR=/srv/md0/arda/runtime
DATA_DIR=/srv/md0/arda/data
BACKUP_DIR=/srv/md0/arda/backup

# -- Domain --------------------------------------------------------------------
APEX_DOMAIN=arda.vxture.com

# -- Tailnet exposure ----------------------------------------------------------
# Host port arda-app is published on the deploy host's tailnet, so the shared public
# edge can reach it over tailscale (WireGuard-encrypted). the deploy host has no public
# IP; the host firewall must allow ingress on the tailscale interface only. beta
# uses 3231 to coexist with prod's 3230 on the same host.
APP_PUBLISH_PORT=3230

# -- OIDC RP (Vxture App Integration Standard v1.0) ----------------------------
# arda is a cross-domain OIDC Authorization-Code + PKCE RP against
# accounts.vxture.com, the single identity center for the whole product. The
# app is the RP / app-bff: it holds tokens server-side in Redis and the browser
# only ever sees an opaque session cookie. OIDC_ISSUER + OIDC_CLIENT_SECRET must
# both be set for login to work.
OIDC_ISSUER=https://accounts.vxture.com
OIDC_CLIENT_ID=arda
# Provisioned by the platform via secret manager; never commit the real value.
OIDC_CLIENT_SECRET=
# Must exactly match a registered redirect_uri on the arda oidc_client.
OIDC_REDIRECT_URI=https://arda.vxture.com/auth/callback
# Quote: the deploy sources .env via bash, which would word-split bare spaces.
OIDC_SCOPES="openid profile email arda:subscription"
# Post-logout landing; the app root is fine (anonymous, no loop).
OIDC_POST_LOGOUT_REDIRECT_URI=https://arda.vxture.com/

# -- Server-side RP session store ----------------------------------------------
# arda-redis on this stack's compose network. The host part must match the redis
# container_name (${PROJECT_NAME}-redis), so it differs between prod and beta.
REDIS_URL=redis://arda-redis:6379
# RP session lifetime in seconds (keep <= refresh TTL; default 30d).
RP_SESSION_TTL=2592000
# Opaque session cookie name.
RP_SESSION_COOKIE_NAME=vx_rp_session
# Host-only cookie (NO leading dot): scoped to this exact domain only.
RP_SESSION_COOKIE_DOMAIN=arda.vxture.com

# -- App config ----------------------------------------------------------------
# Default post-login landing route.
DEFAULT_LANDING=/dashboard

# -- Arda claim mock (local dev / CI without a real IdP) ----------------------
# When accounts.vxture.com does not yet emit the `arda` scope claim, these env
# vars drive MockEntitlementResolver. Remove once accounts emits the real claim.
#   MOCK_STATE: trial | subscribed | expired | free  (default: subscribed)
#   MOCK_TIER:  free | pro | team | enterprise       (default: pro)
# For beta-stack local dev, set MOCK_STATE=trial so EnvGuard does not redirect.
MOCK_STATE=subscribed
MOCK_TIER=pro

# -- Client-side stack identity (NEXT_PUBLIC_ = baked into the browser bundle) -
# NEXT_PUBLIC_APP_ENV identifies which stack this build targets so EnvGuard
# can redirect users to the correct stack if they land on the wrong one.
# NEXT_PUBLIC_PROD_URL / NEXT_PUBLIC_BETA_URL are the redirect targets.
NEXT_PUBLIC_APP_ENV=prod
NEXT_PUBLIC_PROD_URL=https://arda.vxture.com
NEXT_PUBLIC_BETA_URL=https://beta-arda.vxture.com

# -- Container Images ----------------------------------------------------------
# GHCR is primary: ${IMAGE_REGISTRY}/${IMAGE_NAMESPACE}/<image>:${IMAGE_TAG}.
# Owned image: arda-app (the only image arda builds). FALLBACK_IMAGE_* is the
# Aliyun ACR pull-through used by the deploy script when GHCR is unreachable.
IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=vxture
IMAGE_TAG=latest
FALLBACK_IMAGE_REGISTRY=crpi-l3l7g186zpo2if7p.cn-hangzhou.personal.cr.aliyuncs.com
FALLBACK_IMAGE_NAMESPACE=agentos

# -- Shared edge ---------------------------------------------------
# TLS termination and the *.vxture.com wildcard cert live on the SHARED public
# edge, not here. arda only contributes the vhost source artifacts in
# configs/edge/*.conf; an operator drops them into the vxture project
# repository and runs 20-sync-nginx-config.sh on
# the edge host. The edge upstream targets ARDA_DEPLOY_HOST:${APP_PUBLISH_PORT} (MagicDNS
# name) over tailscale. None of the edge config is consumed by this app stack -
# this stack is plain HTTP on the tailnet; the edge is the only TLS hop.

# -- Private packages ----------------------------------------------------------
# Published package source for @vxture/* packages.
# GitHub Packages default: https://npm.pkg.github.com
VXTURE_NPM_REGISTRY=https://npm.pkg.github.com
# Token with package read access. Keep only in .env or CI secrets.
NODE_AUTH_TOKEN=

# ==============================================================================
# BETA OVERRIDES (pre-release stack, on md1 916G RAID-1)
# For /srv/md1/arda-beta/etc/.env, keep everything above but change these lines:
#
#   PROJECT_NAME=arda-beta
#   ROOT_DIR=/srv/md1/arda-beta
#   REPO_DIR=/srv/md1/arda-beta/deploy
#   RUNTIME_DIR=/srv/md1/arda-beta/runtime
#   DATA_DIR=/srv/md1/arda-beta/data
#   BACKUP_DIR=/srv/md1/arda-beta/backup
#   APEX_DOMAIN=beta-arda.vxture.com
#   APP_PUBLISH_PORT=3231
#   OIDC_REDIRECT_URI=https://beta-arda.vxture.com/auth/callback
#   OIDC_POST_LOGOUT_REDIRECT_URI=https://beta-arda.vxture.com/
#   REDIS_URL=redis://arda-beta-redis:6379
#   RP_SESSION_COOKIE_DOMAIN=beta-arda.vxture.com
#   MOCK_STATE=trial
#   NEXT_PUBLIC_APP_ENV=beta
#
# OIDC_CLIENT_ID stays "arda" for both stacks (single product, single client).
# Both redirect_uris must be registered on the arda OIDC client in accounts.
# ==============================================================================
