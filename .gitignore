# Environment - never commit real secrets
.env
*.env
.env.*
!.env.example
!.env.local.example
!deploy/env/*.env
.env.bak.*
.npmrc
# The workspace .npmrc files only declare the @vxture GitHub Packages registry
# and reference ${NODE_AUTH_TOKEN} (no literal secret). They MUST be committed so
# CI `pnpm install` can resolve @vxture/* packages.
!.npmrc
!portals/.npmrc

# Runtime data and generated configs
data/
backup/
private/
runtime/
generated/

# TLS / certificates
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

# Logs
*.log
logs/
# ...but app-router source dirs named "logs" (e.g. /operations/logs,
# /integration/logs) are SOURCE, not runtime logs - keep them tracked.
!portals/app/app/**/logs/

# Node / Next.js
node_modules/
.npm-cache/
.next/
out/
build/
dist/
portals/app/.next/
portals/packages/shared/dist/
*.tsbuildinfo
next-env.d.ts

# Test / coverage
coverage/
.nyc_output/

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp
*.swo

.claude/

# Python bytecode (local compileall artifacts)
__pycache__/
*.pyc
