# Local development config. Copy this file to .env.local and edit as needed.
# .env.local is git-ignored and never committed.
#
# Requires a local Redis. Start it with:
#   docker run -d --name arda-redis-dev -p 6379:6379 redis:7-alpine
# Stop / clean up:
#   docker stop arda-redis-dev && docker rm arda-redis-dev
#
# Then run the app:
#   pnpm --filter @arda/app run dev
#
# The app opens at http://localhost:3230
# Because MOCK_AUTH=true, opening the app auto-creates a mock session.
# To switch the active user state, visit one of the quick-switch URLs:
#
#   http://localhost:3230/auth/dev-login?state=subscribed&tier=pro
#   http://localhost:3230/auth/dev-login?state=subscribed&tier=team
#   http://localhost:3230/auth/dev-login?state=subscribed&tier=enterprise
#   http://localhost:3230/auth/dev-login?state=trial&tier=pro
#   http://localhost:3230/auth/dev-login?state=expired
#   http://localhost:3230/auth/dev-login?state=free
#   http://localhost:3230/auth/dev-login?state=trial&had_trial=true
#
# To test EnvGuard redirect behavior, change NEXT_PUBLIC_APP_ENV:
#   NEXT_PUBLIC_APP_ENV=beta  + state=subscribed -> redirects to NEXT_PUBLIC_PROD_URL
#   NEXT_PUBLIC_APP_ENV=prod  + state=trial      -> redirects to NEXT_PUBLIC_BETA_URL
# (The redirects go to localhost URLs below, not the real vxture.com domains.)

# -- Mock auth (bypasses OIDC, creates session directly in Redis) -------------
MOCK_AUTH=true
MOCK_STATE=subscribed
MOCK_TIER=pro

# -- Redis (local docker) -----------------------------------------------------
REDIS_URL=redis://localhost:6379
RP_SESSION_TTL=86400
RP_SESSION_COOKIE_NAME=vx_rp_session
# Empty = host-only default for localhost (do not set to "localhost").
RP_SESSION_COOKIE_DOMAIN=

# -- App ----------------------------------------------------------------------
DEFAULT_LANDING=/data-assets/overview

# -- Client-side stack identity -----------------------------------------------
# Change to "beta" to simulate the beta stack (EnvGuard checks this at runtime).
NEXT_PUBLIC_APP_ENV=prod
# Point to localhost so EnvGuard redirects stay local instead of going to prod.
NEXT_PUBLIC_PROD_URL=http://localhost:3230
NEXT_PUBLIC_BETA_URL=http://localhost:3231
