// Arda domain schema (v1, catalog-first).
//
// Source of truth for these entities: docs/30-design/arda-biz-120-domain-entities-and-feature-keys.md.
// Scope: catalog + metadata + governance at the DATASET level. Integration data
// movement (Pipeline/JobRun) and column-level Field are `future` and are NOT
// modeled here. Platform/IdP-owned concepts (Org, workspace lifecycle,
// Subscription, members, billing) are NOT modeled - arda only mirrors workspaces
// and reads entitlement live from the platform.
//
// Isolation: every business entity carries `workspaceId` (the platform/IdP
// `active_workspace`) and is force-filtered by it. It is a plain indexed column,
// not a FK - workspace lifecycle is platform-owned, so rows must not depend on a
// local WorkspaceRef existing first.
//
// Physical schemas (ADR-012 / data_platform_100 2.3.1): contract schemas
// vx_provision (provisioning + webhook ledger), local_usage (usage buffer),
// local_authz (product RBAC - EMPTY today, no models) + the product domain
// schema `catalog` (all business tables). Prisma MODEL names are kept; only the
// four contract tables are physically renamed via @@map. multiSchema requires
// every model and enum to declare @@schema.

// Prisma 7 Rust-free client (queryCompiler + driver adapter). Generated ESM
// client lives under app/generated/prisma (gitignored, emitted at build).
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["catalog", "local_authz", "local_usage", "vx_provision"]
}

/// Security classification of an asset (dataset-level in v1).
enum AssetLevel {
  public
  internal
  sensitive
  core

  @@schema("catalog")
}

/// Outcome of a single quality check run.
enum QualityStatus {
  pass
  warn
  fail

  @@schema("catalog")
}

/// Data ownership scope - the EXPLICIT axis that distinguishes tenant data from
/// platform-global reference data (data_platform_100 2.3.2: a product must NOT
/// fabricate a workspace_id sentinel; workspace_id is platform-issued). `workspace`
/// = tenant-owned, isolated to and shared only within its workspace (across the
/// agents present in that workspace). `platform` = arda-ops-curated global
/// reference data (approved standards, admin-division code tables, currency
/// codes), read-only to ALL workspaces.
///
/// Platform rows carry `workspaceId = NULL` (NULL = platform-global; they belong
/// to no workspace) together with `scope = platform`; the two are kept in lockstep
/// (scope=platform iff workspaceId IS NULL). A tenant read overlays them via
/// `workspaceId = self OR workspaceId IS NULL`. Writing a `platform` row requires
/// the ops/platform role, never a tenant user. See
/// docs/30-design/arda-data-150-multiagent-sharing.md.
enum AssetScope {
  workspace
  platform

  @@schema("catalog")
}

// --------------------------------------------------------------- assets ------

model Dataset {
  id            String      @id @default(cuid())
  // NULL = platform-global reference asset (scope=platform); otherwise the
  // owning workspace. Plain indexed column, not a FK (data-110 1).
  workspaceId   String?
  dataSourceId  String?
  name          String
  // Technical slug shown in the catalog (e.g. dw_customer_master).
  code          String
  description   String?
  // Catalog facets: subject domain + owning team (free-form keys). Quality score
  // and subscriber count are deliberately NOT stored - they are derived later
  // (QualityResult aggregate / subscription join) and shown as "-" until then.
  domain        String?
  team          String?
  refreshFreq   String? // realtime | daily | weekly | monthly
  type          String // table | view | file | stream
  location      String?
  rowCountEst   BigInt?
  sizeBytes     BigInt?
  ownerUserId   String?
  // Producing agent/app within the workspace (attribution + provenance; NOT an
  // isolation axis - workspaceId is). Lets multiple agents in one workspace share
  // via arda while keeping "who produced this" first-class.
  ownerApp      String?
  // M-BL1 (biz-432): authoritative golden-record mark for master-data
  // governance; lightweight v1 - matching/merge engines stay future.
  goldenRecord  Boolean     @default(false)
  classification AssetLevel @default(internal)
  // platform = ops-curated global reference asset (workspaceId NULL), read-only
  // overlay into every workspace; workspace = tenant-owned.
  scope         AssetScope  @default(workspace)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  source         DataSource?     @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)
  tags           DatasetTag[]
  qualityRules   QualityRule[]
  qualityResults QualityResult[]
  lineageOut     LineageEdge[]   @relation("LineageUpstream")
  lineageIn      LineageEdge[]   @relation("LineageDownstream")
  services       DataServiceDataset[]
  standards      DatasetStandard[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@index([workspaceId, dataSourceId])
  @@index([workspaceId, domain])
  @@index([workspaceId, ownerApp])
  @@schema("catalog")
}

model Tag {
  id          String       @id @default(cuid())
  workspaceId String
  name        String
  color       String?
  datasets    DatasetTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@schema("catalog")
}

model DatasetTag {
  datasetId   String
  tagId       String
  workspaceId String

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([datasetId, tagId])
  @@index([workspaceId])
  @@schema("catalog")
}

model GlossaryTerm {
  id            String  @id @default(cuid())
  // NULL = platform-global term (scope=platform); otherwise the owning workspace.
  workspaceId   String?
  term          String
  definition    String
  stewardUserId String?
  // platform = ops-approved global glossary shared to all workspaces
  // (workspaceId NULL); workspace = tenant-local term.
  scope         AssetScope @default(workspace)

  @@unique([workspaceId, term])
  @@index([workspaceId])
  @@schema("catalog")
}

// ----------------------------------------------------------- integration -----

/// v1: registration + schema/metadata pull only - no actual data movement.
model DataSource {
  id              String    @id @default(cuid())
  workspaceId     String
  // Catalog quad (arda_000 2.1): every DataSource is registered under
  // (org, ws, product, datasource). orgId = absolute isolation boundary
  // (platform active_org); productCode = the product owning the source
  // ("arda" for external/customer sources; the L3 product_code for internal
  // agent-db sources, e.g. "umbra"). Plain columns, no FKs (data-110 1).
  orgId           String?
  productCode     String    @default("arda")
  name            String
  type            String // agent_db | postgres | mysql | rest | file | s3 | bigquery | snowflake
  connectionConfig Json?   // encrypted at the app layer before persistence
  status          String    @default("connected")
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())

  datasets Dataset[]

  @@index([workspaceId])
  @@index([orgId])
  @@schema("catalog")
}

// ------------------------------------------------------------- governance ----

model Policy {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  type        String // access | masking | retention | classification
  scope       String // dataset | tag | source
  config      Json?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@schema("catalog")
}

/// Data access / sharing request (Sec-BL4): a workspace member asks for access
/// to an asset; a workspace admin approves or rejects. Insert-once request
/// body; only the decision columns (status/decidedBy/decidedAt/decisionNote)
/// mutate - see 98_column_locks.sql.
model AccessRequest {
  id            String    @id @default(cuid())
  workspaceId   String
  datasetId     String?
  requesterSub  String
  requesterName String?
  useCase       String
  scope         String?
  justification String
  duration      String?
  method        String?
  status        String    @default("pending") // pending | approved | rejected | cancelled
  decidedBy     String?
  decidedAt     DateTime?
  decisionNote  String?
  createdAt     DateTime  @default(now())

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@schema("catalog")
}

model QualityRule {
  id          String   @id @default(cuid())
  workspaceId String
  datasetId   String
  code        String // display id, e.g. Q-201
  name        String
  dimension   String // quality dimension key: completeness | accuracy | ...
  type        String // not_null | unique | range | freshness | ...
  config      Json?
  severity    String   @default("warning")
  enabled     Boolean  @default(true)

  dataset Dataset         @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  results QualityResult[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@index([datasetId])
  @@schema("catalog")
}

model QualityResult {
  id          String        @id @default(cuid())
  workspaceId String
  ruleId      String
  datasetId   String
  runAt       DateTime      @default(now())
  status      QualityStatus
  score       Float? // pass rate %
  issues      Int           @default(0)
  details     Json?

  rule    QualityRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  dataset Dataset     @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([ruleId])
  @@index([datasetId])
  @@schema("catalog")
}

/// Data standard: a code set or data element reference (metadata governance).
model Standard {
  id          String   @id @default(cuid())
  // NULL = platform-global standard (scope=platform); otherwise owning workspace.
  workspaceId String?
  code        String // e.g. STD-001
  name        String
  type        String // code-set | data-element
  ref         String // reference spec (e.g. ISO 3166-1)
  items       Int      @default(0)
  usage       Int      @default(0)
  status      String   @default("draft") // published | draft | review
  // platform = ops-approved global reference (e.g. code sets like admin-division
  // codes), read-only to all workspaces (workspaceId NULL); workspace =
  // tenant-local draft. Promotion workspace->platform is an ops action.
  scope       AssetScope @default(workspace)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  datasets    DatasetStandard[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@schema("catalog")
}

model LineageEdge {
  id                 String  @id @default(cuid())
  workspaceId        String
  upstreamDatasetId  String
  downstreamDatasetId String
  transform          String?
  jobId              String?

  upstream   Dataset @relation("LineageUpstream", fields: [upstreamDatasetId], references: [id], onDelete: Cascade)
  downstream Dataset @relation("LineageDownstream", fields: [downstreamDatasetId], references: [id], onDelete: Cascade)

  @@unique([upstreamDatasetId, downstreamDatasetId])
  @@index([workspaceId])
  @@schema("catalog")
}

// --------------------------------------------------------------- services ----

model DataService {
  id          String     @id @default(cuid())
  workspaceId String
  code        String // display id, e.g. API-1042
  name        String
  path        String // e.g. /api/v2/customer/verify
  method      String     @default("GET") // GET | POST
  description String?
  domain      String?
  level       AssetLevel @default(internal)
  type        String // rest_api | query | export | share
  config      Json?
  status      String     @default("draft") // draft | running | review | paused
  ownerApp    String?    // publishing agent/app within the workspace
  visibility  String     @default("workspace") // workspace = shared to all agents in the workspace; owner = private to the owner app
  publishedAt DateTime?
  createdAt   DateTime   @default(now())

  datasets DataServiceDataset[]
  apiKeys  ApiKey[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@schema("catalog")
}

/// S-BL1 (biz-431): dataset-level standard-compliance association. Column-level
/// compliance rides the future Field model. workspaceId is a denormalized carry
/// column (data-110 3.2), NULL for platform-global links; platform-scope
/// standards may be referenced by any workspace (read-only overlay).
model DatasetStandard {
  datasetId   String
  standardId  String
  workspaceId String?

  dataset  Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  standard Standard @relation(fields: [standardId], references: [id], onDelete: Cascade)

  @@id([datasetId, standardId])
  @@index([workspaceId])
  @@index([standardId])
  @@schema("catalog")
}

model DataServiceDataset {
  dataServiceId String
  datasetId     String
  workspaceId   String

  service DataService @relation(fields: [dataServiceId], references: [id], onDelete: Cascade)
  dataset Dataset     @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@id([dataServiceId, datasetId])
  @@index([workspaceId])
  @@schema("catalog")
}

// ------------------------------------------------------------------ admin ----

model ApiKey {
  id            String    @id @default(cuid())
  workspaceId   String
  dataServiceId String?
  name          String
  consumerApp   String?   // the agent/app this key authenticates as (consumer identity for audit + policy)
  hashedKey     String    @unique
  scopes        String[]
  lastUsedAt    DateTime?
  revoked       Boolean   @default(false)
  createdAt     DateTime  @default(now())

  service DataService? @relation(fields: [dataServiceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@schema("catalog")
}

/// Activity + platform-command audit (seed/wipe/invalidate, ADR section 5.1).
model AuditLog {
  id             String   @id @default(cuid())
  workspaceId    String
  actor          String // a user id or "platform"
  action         String
  target         String?
  idempotencyKey String?  @unique
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@schema("catalog")
}

// ------------------------------------------------------- infrastructure ------

/// Local mirror of a platform workspace, used purely as the isolation anchor.
/// arda does NOT own workspace lifecycle (create/clone/delete = platform).
/// tenantId and plan are set by the C3 provisioning webhook on first provisioning.
/// status: provisioned | deprovisioned (deprovisioned rows retained for audit).
/// Physical: vx_provision.app_instance (ADR-012).
model WorkspaceRef {
  id         String   @id // = platform/IdP active_workspace
  orgId      String
  tenantId   String? // from provisioning webhook payload
  plan       String? // arda plan code at last provisioning
  status     String   @default("provisioned") // provisioned | deprovisioned | hard_deleted
  seedStatus String? // platform marker: needs sample-data fill (ADR section 4)
  // Soft-delete mark (Lc-BL3 ruling 2026-07-14): the wipe unit is the WHOLE
  // workspace, so the mark lives here on the anchor - business tables carry no
  // per-row deletedAt. Set on tenant.deprovisioned, CLEARED on re-provision
  // (the ADR 5.1 recovery window); hard delete sweeps after RETENTION_DAYS.
  wipedAt    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orgId])
  @@index([wipedAt])
  @@index([status])
  @@map("app_instance")
  @@schema("vx_provision")
}

/// Per-delivery idempotency ledger for inbound C3 provisioning webhook events
/// (vx_provision.webhook_delivery). id = platform delivery uuid; a repeat
/// delivery id is a duplicate. The processed-seq watermark lives in ProvisionSeq
/// (provision_seq), split out per ADR-012 / data_platform_100 2.3.1.
model WebhookDelivery {
  id          String   @id // platform delivery uuid (x-vxture-delivery header)
  workspaceId String
  tenantId    String
  eventType   String // tenant.provisioned | tenant.deprovisioned | subscription_changed
  seq         Int
  plan        String?
  processedAt DateTime @default(now())

  @@index([workspaceId])
  @@map("webhook_delivery")
  @@schema("vx_provision")
}

/// Processed-seq watermark per (workspaceId, productCode) for inbound C3
/// provisioning events (vx_provision.provision_seq). Replaces the old
/// MAX(seq)-over-the-ledger derivation with an explicit watermark row: an event
/// with seq <= lastSeq is stale (handoff SS2 wire contract).
model ProvisionSeq {
  workspaceId String
  productCode String   @default("arda")
  lastSeq     Int
  updatedAt   DateTime @updatedAt

  @@id([workspaceId, productCode])
  @@map("provision_seq")
  @@schema("vx_provision")
}

/// Read-only, versioned sample-data templates (global, platform/ops-curated).
/// NOT workspace-scoped.
model SeedTemplate {
  id        String            @id @default(cuid())
  name      String
  createdAt DateTime          @default(now())
  versions  TemplateVersion[]

  @@schema("catalog")
}

model TemplateVersion {
  id         String       @id @default(cuid())
  templateId String
  version    String
  manifest   Json
  createdAt  DateTime     @default(now())

  template SeedTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@schema("catalog")
}

// ------------------------------------------------------- local_usage ----------

/// C3 usage buffer: records are written on each billable action and flushed to
/// the platform consume endpoint (POST /usage/consume) by the ConsumeFlushJob.
/// Physical: local_usage.raw (ADR-012).
/// idempotencyKey: caller-supplied; replayed platform calls return replayed:true.
/// flushed: false until the platform consume call returns 200 or 409 (quota
/// exhausted counts as consumed). Failed calls remain flushed=false for retry.
model UsageRaw {
  id             String   @id @default(cuid())
  workspaceId    String
  product        String   @default("arda")
  metric         String // e.g. datasource.registered | query.count (TBD: owner decision)
  amount         Int      @default(1)
  idempotencyKey String   @unique
  flushed        Boolean  @default(false)
  flushAttempts  Int      @default(0)
  flushError     String?
  createdAt      DateTime @default(now())
  flushedAt      DateTime?

  @@index([flushed, createdAt])
  @@index([workspaceId])
  @@map("raw")
  @@schema("local_usage")
}
