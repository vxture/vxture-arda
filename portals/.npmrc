@vxture:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
# Next.js standalone build + the deps-stage COPY assume a flat, hoisted
# node_modules (as npm produced). pnpm defaults to an isolated store, so pin the
# hoisted linker to keep the build working after the D4 npm->pnpm migration.
node-linker=hoisted
